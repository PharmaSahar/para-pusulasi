# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# YouTube Data API v3 (Google Cloud Console)
YOUTUBE_CLIENT_ID=your_google_client_id_here
YOUTUBE_CLIENT_SECRET=your_google_client_secret_here
YOUTUBE_REDIRECT_URI=http://localhost:8080/callback

# ElevenLabs TTS (opsiyonel - ücretsiz Edge TTS yerine yüksek kalite ses)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# Pexels Stok Görsel API (ücretsiz - https://www.pexels.com/api/)
PEXELS_API_KEY=your_pexels_api_key_here

# Kanal Ayarları
CHANNEL_NICHE=kisisel_finans
CHANNEL_LANGUAGE=tr
DEFAULT_CATEGORY_ID=22
# Kategori ID'leri: 22=People&Blogs, 27=Education, 28=Science&Tech

# Video Üretim Ayarları
VIDEO_RESOLUTION=1920x1080
VIDEOS_PER_WEEK=3
UPLOAD_TIME=10:00
UPLOAD_DAYS=Monday,Wednesday,Friday

# Zamanlayıcı
SCHEDULE_ENABLED=true
TIMEZONE=Europe/Istanbul
