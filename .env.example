# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# YouTube Data API v3 (Google Cloud Console)
YOUTUBE_CLIENT_ID=your_google_client_id_here
YOUTUBE_CLIENT_SECRET=your_google_client_secret_here
YOUTUBE_REDIRECT_URI=http://localhost:8080/callback

# ElevenLabs TTS (opsiyonel - ücretsiz Edge TTS yerine yüksek kalite ses)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# Pexels Stok Görsel API (ücretsiz - https://www.pexels.com/api/)
PEXELS_API_KEY=your_pexels_api_key_here
OPENAI_IMAGE_ENABLED=false

# Storyblocks Premium API (opsiyonel)
STORYBLOCKS_API_KEY=your_storyblocks_api_key_here
STORYBLOCKS_PUBLIC_KEY=your_storyblocks_public_key_here
STORYBLOCKS_PRIVATE_KEY=your_storyblocks_private_key_here
STORYBLOCKS_USER_ID=your_storyblocks_user_id_here
STORYBLOCKS_PROJECT_ID=your_storyblocks_project_id_here
# Opsiyonel: Storyblocks farklı endpoint verdiyse buradan override edin
STORYBLOCKS_SEARCH_URL=https://api.storyblocks.com/api/v2/videos/search

# Kanal Ayarları
CHANNEL_NICHE=kisisel_finans
CHANNEL_LANGUAGE=tr
DEFAULT_CATEGORY_ID=22
# Kategori ID'leri: 22=People&Blogs, 27=Education, 28=Science&Tech

# Video Üretim Ayarları
VIDEO_RESOLUTION=1920x1080
VIDEOS_PER_WEEK=3
UPLOAD_TIME=10:00
UPLOAD_DAYS=Monday,Wednesday,Friday

# Zamanlayıcı
SCHEDULE_ENABLED=true
TIMEZONE=Europe/Istanbul
